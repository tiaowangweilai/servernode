<launch>
    <let name ="urdf_path"
         value="$(find-pkg-share agv_description)/urdf/agv_robot.urdf.xacro"/>
    <let name ="rviz_config_path"
         value="$(find-pkg-share agv_bringup)/config/agv_moveit.rviz"/>

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description"
                value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="controller_manager" exec="ros2_control_node">
        <param from="$(find-pkg-share agv_bringup)/config/ros2_controllers.yaml" />
    </node>

    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" />
    <node pkg="controller_manager" exec="spawner" args="agvBase_controller" />
    <node pkg="controller_manager" exec="spawner" args="arm1_controller" />
    <node pkg="controller_manager" exec="spawner" args="arm2_controller" />

    <include file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
        <arg name="align_depth.enable" value="true" />
        <arg name="rgb_camera.color_profile" value="640x480x30" />
        <arg name="depth_module.depth_profile" value="640x480x30" />
    </include>

    <include file="$(find-pkg-share agv_moveit_config)/launch/move_group.launch.py" />

    <node pkg="rviz2" exec="rviz2" output="screen" 
          args="-d $(var rviz_config_path)"/>
</launch>